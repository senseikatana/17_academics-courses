<button
  id="theme-toggle"
  class="fixed bottom-6 right-6 flex items-center justify-center w-12 h-12 rounded-full z-50
         bg-[var(--color-card)] text-[var(--color-text)]
         border border-[var(--color-border)]
         shadow-[var(--shadow-lg)]
         hover:shadow-[var(--shadow-md)]
         hover:scale-110 active:scale-95
         focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]
         transition-transform duration-300 ease-out
         cursor-pointer"
  title="Cambiar a modo oscuro (Ctrl+L)"
>
  <span id="theme-icon" class="text-xl leading-none">🌙</span>
</button>

<script>
  const KEY = 'theme-preference';

  function getTheme() {
    try {
      return localStorage.getItem(KEY) || 'light';
    } catch {
      return 'light';
    }
  }

  function setTheme(val: string) {
    try {
      localStorage.setItem(KEY, val);
    } catch {}
  }

  function aplicar(theme: string) {
    const html = document.documentElement;
    html.classList.remove('dark', 'light');
    html.classList.add(theme);
    setTheme(theme);

    const btn = document.getElementById('theme-toggle');
    const icono = document.getElementById('theme-icon');
    if (btn && icono) {
      const esDark = theme === 'dark';
      icono.textContent = esDark ? '☀️' : '🌙';
      const label = esDark
        ? 'Cambiar a modo claro (Ctrl+L)'
        : 'Cambiar a modo oscuro (Ctrl+L)';
      btn.setAttribute('title', label);
      btn.setAttribute('aria-label', label);
    }
  }

  function toggle() {
    aplicar(getTheme() === 'dark' ? 'light' : 'dark');
  }

  function initTheme() {
    const btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.onclick = toggle;
    }
    aplicar(getTheme());
  }

  // Ejecutar en la carga inicial y en cada transición de página
  initTheme();
  document.addEventListener('astro:page-load', initTheme);

  // Registrar el atajo de teclado solo una vez a nivel global
  if (typeof window !== 'undefined' && !(window as any).__themeKeydown) {
    (window as any).__themeKeydown = true;
    document.addEventListener('keydown', (e) => {
      if (e.ctrlKey && e.key.toLowerCase() === 'l') {
        e.preventDefault();
        toggle();
      }
    });
  }
</script>
