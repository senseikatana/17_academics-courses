---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { db, Seccion, Leccion, ProgresoLeccion, and, eq } from 'astro:db';
import { SeccionProgressTracker } from '../../components';
import type { Curso } from '../../types';

const { slug } = Astro.params;
const cursoId = 'astro-ccj-udemy';

// Obtener todas las Secciones desde Astro DB para el curso actual
const dbSecciones = await db.select().from(Seccion).where(eq(Seccion.cursoId, cursoId));
dbSecciones.sort((a, b) => a.orden - b.orden);

const dbSeccion = dbSecciones.find((s) => s.slug === slug);
if (!dbSeccion) {
  return Astro.redirect('/404');
}

const seccion = {
  data: {
    id: dbSeccion.id.replace(`${cursoId}-`, ''),
    titulo: dbSeccion.titulo,
    slug: dbSeccion.slug,
    orden: dbSeccion.orden
  }
};

// Obtener Lecciones desde Astro DB para la sección actual
const dbLecciones = await db.select().from(Leccion).where(eq(Leccion.seccionId, dbSeccion.id));
const lecciones = dbLecciones
  .sort((a, b) => a.orden - b.orden)
  .map((l) => ({
    data: {
      id: l.id.replace(`${cursoId}-`, ''),
      titulo: l.titulo,
      seccionId: l.seccionId.replace(`${cursoId}-`, ''),
      orden: l.orden
    }
  }));

const idx = dbSecciones.findIndex((s) => s.id === dbSeccion.id);
const seccionAnterior = idx > 0 ? {
  data: {
    id: dbSecciones[idx - 1].id.replace(`${cursoId}-`, ''),
    titulo: dbSecciones[idx - 1].titulo,
    slug: dbSecciones[idx - 1].slug,
    orden: dbSecciones[idx - 1].orden
  }
} : null;
const seccionSiguiente = idx < dbSecciones.length - 1 ? {
  data: {
    id: dbSecciones[idx + 1].id.replace(`${cursoId}-`, ''),
    titulo: dbSecciones[idx + 1].titulo,
    slug: dbSecciones[idx + 1].slug,
    orden: dbSecciones[idx + 1].orden
  }
} : null;

const [curso]: Curso[] = await getCollection('curso');

// Obtener lecciones completadas desde Astro DB
const completedRows = await db
  .select()
  .from(ProgresoLeccion)
  .where(
    and(
      eq(ProgresoLeccion.cursoId, cursoId),
      eq(ProgresoLeccion.seccionSlug, slug || '')
    )
  );
const completedIds = completedRows.map((row) => row.leccionId.replace(`${cursoId}-`, ''));

// Serializar las lecciones para pasarlas como props al componente de React
const serializedLecciones = lecciones.map((l) => ({
  id: l.data.id,
  titulo: l.data.titulo,
}));
---

<BaseLayout title={`${seccion.data.id}. ${seccion.data.titulo} — ${curso.data.titulo}`}>
  <main id="seccion-container" class="min-h-screen px-4 sm:px-6 lg:px-8 py-12" data-slug={slug} transition:animate="fade">
    <div class="max-w-2xl mx-auto">
      <!-- Navegación superior -->
      <nav class="mb-6">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                 hover:text-[var(--color-primary-hover)] transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al índice
        </a>
      </nav>

      <!-- Cabecera de la sección -->
      <header class="mb-8">
        <span class="pill-badge mb-3">
          Sección {seccion.data.id}
        </span>
        <h1
          class="text-2xl sm:text-3xl font-extrabold text-[var(--color-heading)] leading-tight"
        >
          {seccion.data.titulo}
        </h1>
        <p class="mt-1 text-sm text-[var(--color-muted)]">
          {lecciones.length} lecciones
        </p>

        {/* Componente de React hidratado (Astro Island) que maneja el progreso y los checkboxes */}
        <SeccionProgressTracker
          client:load
          seccionSlug={slug || ''}
          lecciones={serializedLecciones}
          initialCompleted={completedIds}
        />
      </header>

      <!-- Navegación entre secciones -->
      <nav class="mt-10 flex items-center justify-between border-t border-[var(--color-border)] pt-6">
        {seccionAnterior ? (
          <a
            href={`/secciones/${seccionAnterior.data.slug}`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                   hover:text-[var(--color-primary-hover)] transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            {seccionAnterior.data.titulo}
          </a>
        ) : (
          <div></div>
        )}

        {seccionSiguiente ? (
          <a
            href={`/secciones/${seccionSiguiente.data.slug}`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                   hover:text-[var(--color-primary-hover)] transition-colors"
          >
            {seccionSiguiente.data.titulo}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div></div>
        )}
      </nav>
    </div>
  </main>
</BaseLayout>
