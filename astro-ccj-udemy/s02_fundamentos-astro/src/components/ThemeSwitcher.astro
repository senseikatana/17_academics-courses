<button
  id="theme-toggle"
  class="fixed bottom-6 right-6 flex items-center justify-center w-12 h-12 rounded-full z-50
         bg-[var(--color-card)] text-[var(--color-text)]
         border border-[var(--color-border)]
         shadow-[var(--shadow-lg)]
         hover:shadow-[var(--shadow-md)]
         hover:scale-110 active:scale-95
         focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]
         transition-transform duration-300 ease-out
         cursor-pointer"
  title="Cambiar a modo oscuro (Ctrl+L)"
>
  <span id="theme-icon">🌕</span>
</button>

<script>
  (function () {
    var KEY = 'theme-preference';
    var btn = document.getElementById('theme-toggle');
    var icono = document.getElementById('theme-icon');
    var html = document.documentElement;

    function safeGet(fallback) {
      try { return localStorage.getItem(KEY) || fallback; } catch { return fallback; }
    }

    function safeSet(val) {
      try { localStorage.setItem(KEY, val); } catch {}
    }

    function aplicar(theme) {
      html.classList.remove('dark', 'light');
      html.classList.add(theme);
      var esDark = theme === 'dark';
      icono.textContent = esDark ? '☀️' : '🌕';
      var label = esDark
        ? 'Cambiar a modo claro (Ctrl+L)'
        : 'Cambiar a modo oscuro (Ctrl+L)';
      btn.setAttribute('title', label);
      btn.setAttribute('aria-label', label);
      safeSet(theme);
    }

    function toggle() {
      aplicar(safeGet('light') === 'dark' ? 'light' : 'dark');
    }

    btn.onclick = toggle;

    if (!window.__themeKeydown) {
      window.__themeKeydown = true;
      document.addEventListener('keydown', function (e) {
        if (e.ctrlKey && e.key.toLowerCase() === 'l') {
          e.preventDefault();
          toggle();
        }
      });
    }

    aplicar(safeGet('light'));
  })();
</script>
