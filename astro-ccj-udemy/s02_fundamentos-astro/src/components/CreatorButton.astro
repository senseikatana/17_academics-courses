---
import { db, Seccion } from 'astro:db';

const dbSecciones = await db.select().from(Seccion);
dbSecciones.sort((a, b) => a.orden - b.orden);
const secciones = dbSecciones.map((s) => ({
  data: {
    id: s.id,
    titulo: s.titulo,
    slug: s.slug,
    orden: s.orden
  }
}));
---

<!-- Botón Flotante "+" -->
<button
  id="creator-toggle"
  class="fixed bottom-6 right-20 flex items-center justify-center w-12 h-12 rounded-full z-50
         bg-[var(--color-primary)] text-white
         shadow-[var(--shadow-lg)]
         hover:shadow-[var(--shadow-md)]
         hover:scale-110 active:scale-95
         focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]
         transition-transform duration-300 ease-out
         cursor-pointer"
  title="Crear nueva sección o lección"
>
  <span class="text-2xl leading-none font-bold">+</span>
</button>

<!-- Modal Popup -->
<div
  id="creator-modal"
  class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
>
  <div
    class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-2xl shadow-[var(--shadow-lg)] w-full max-w-md overflow-hidden transform scale-95 transition-transform duration-300"
  >
    <!-- Cabecera del Modal -->
    <div class="px-6 py-4 border-b border-[var(--color-border)] flex items-center justify-between">
      <h3 class="text-lg font-bold text-[var(--color-heading)]">Creador de Contenido</h3>
      <button id="creator-close" class="text-[var(--color-muted)] hover:text-[var(--color-text)] cursor-pointer text-xl">&times;</button>
    </div>

    <!-- Pestañas (Tabs) -->
    <div class="flex border-b border-[var(--color-border)] bg-black/5 dark:bg-white/5">
      <button
        id="tab-leccion"
        type="button"
        class="flex-1 py-3 text-sm font-semibold text-[var(--color-primary)] border-b-2 border-[var(--color-primary)] cursor-pointer focus:outline-none"
      >
        Nueva Lección
      </button>
      <button
        id="tab-seccion"
        type="button"
        class="flex-1 py-3 text-sm font-semibold text-[var(--color-muted)] border-b-2 border-transparent hover:text-[var(--color-text)] cursor-pointer focus:outline-none"
      >
        Nueva Sección
      </button>
    </div>

    <!-- Contenido del Formulario -->
    <form id="creator-form" class="p-6 space-y-4">
      <input type="hidden" id="form-tipo" name="tipo" value="leccion" />

      <!-- Campos de Lección -->
      <div id="fields-leccion" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Sección</label>
          <select
            name="seccionId"
            id="form-seccionId"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          >
            {secciones.map((s) => (
              <option value={s.data.id}>
                Sección {s.data.id} - {s.data.titulo}
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Número de Lección (en Udemy)</label>
          <input
            type="number"
            name="lessonNumber"
            id="form-lessonNumber"
            placeholder="Ej: 12"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Título de la Lección</label>
          <input
            type="text"
            name="tituloLeccion"
            id="form-tituloLeccion"
            placeholder="Ej: Añadiendo Interfaces a Props"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Duración (opcional)</label>
          <input
            type="text"
            name="duracion"
            id="form-duracion"
            placeholder="Ej: 7 min"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
      </div>

      <!-- Campos de Sección -->
      <div id="fields-seccion" class="space-y-4 hidden">
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Número de Sección</label>
          <input
            type="text"
            name="seccionNum"
            id="form-seccionNum"
            placeholder="Ej: 05"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Título de la Sección</label>
          <input
            type="text"
            name="tituloSeccion"
            id="form-tituloSeccion"
            placeholder="Ej: Content Collections"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Slug (para ruta/carpeta)</label>
          <input
            type="text"
            name="seccionSlug"
            id="form-seccionSlug"
            placeholder="Ej: 05_content-collections"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-[var(--color-muted)] mb-1">Orden de visualización</label>
          <input
            type="number"
            name="seccionOrden"
            id="form-seccionOrden"
            placeholder="Ej: 5"
            class="w-full px-3.5 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] text-sm"
          />
        </div>
      </div>

      <!-- Mensajes de Estado -->
      <div id="form-status" class="text-xs font-medium text-center hidden py-1"></div>

      <!-- Botones de Acción -->
      <div class="flex gap-3 pt-2">
        <button
          type="button"
          id="btn-cancel"
          class="flex-1 py-2 rounded-lg border border-[var(--color-border)] text-[var(--color-text)] font-semibold text-sm hover:bg-black/5 dark:hover:bg-white/5 cursor-pointer"
        >
          Cancelar
        </button>
        <button
          type="submit"
          class="flex-1 py-2 rounded-lg bg-[var(--color-primary)] text-white font-semibold text-sm hover:opacity-90 cursor-pointer shadow-[var(--shadow-sm)]"
        >
          Crear
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  function setupCreator() {
    const toggleBtn = document.getElementById('creator-toggle');
    const modal = document.getElementById('creator-modal');
    const closeBtn = document.getElementById('creator-close');
    const cancelBtn = document.getElementById('btn-cancel');
    const form = document.getElementById('creator-form') as HTMLFormElement;

    const tabLeccion = document.getElementById('tab-leccion');
    const tabSeccion = document.getElementById('tab-seccion');

    const fieldsLeccion = document.getElementById('fields-leccion');
    const fieldsSeccion = document.getElementById('fields-seccion');
    const formTipo = document.getElementById('form-tipo') as HTMLInputElement;
    const statusDiv = document.getElementById('form-status');

    // Auto-generación de slug en base al título de sección
    const inputTituloSeccion = document.getElementById('form-tituloSeccion') as HTMLInputElement;
    const inputSeccionNum = document.getElementById('form-seccionNum') as HTMLInputElement;
    const inputSeccionSlug = document.getElementById('form-seccionSlug') as HTMLInputElement;
    const inputSeccionOrden = document.getElementById('form-seccionOrden') as HTMLInputElement;

    if (!toggleBtn || !modal) return;

    function slugify(text: string): string {
      return text
        .toString()
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/\s+/g, '-')
        .replace(/[^\w\-]+/g, '')
        .replace(/\-\-+/g, '-')
        .replace(/^-+/, '')
        .replace(/-+$/, '');
    }

    function updateSlugAndOrden() {
      const num = inputSeccionNum.value.trim();
      const rawTitle = inputTituloSeccion.value.trim();
      if (num) {
        inputSeccionOrden.value = String(parseInt(num, 10) || '');
      }
      if (num && rawTitle) {
        inputSeccionSlug.value = `${num}_${slugify(rawTitle)}`;
      } else if (rawTitle) {
        inputSeccionSlug.value = slugify(rawTitle);
      }
    }

    if (inputTituloSeccion && inputSeccionNum && inputSeccionSlug) {
      inputTituloSeccion.addEventListener('input', updateSlugAndOrden);
      inputSeccionNum.addEventListener('input', updateSlugAndOrden);
    }

    function openModal() {
      if (!modal) return;
      modal.classList.remove('opacity-0', 'pointer-events-none');
      const innerCard = modal.querySelector('div');
      if (innerCard) innerCard.classList.remove('scale-95');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('opacity-0', 'pointer-events-none');
      const innerCard = modal.querySelector('div');
      if (innerCard) innerCard.classList.add('scale-95');
      if (form) form.reset();
      if (statusDiv) {
        statusDiv.classList.add('hidden');
        statusDiv.textContent = '';
      }
    }

    toggleBtn.onclick = openModal;
    if (closeBtn) closeBtn.onclick = closeModal;
    if (cancelBtn) cancelBtn.onclick = closeModal;

    // Cierre al hacer click en el fondo del modal
    modal.onclick = (e) => {
      if (e.target === modal) closeModal();
    };

    // Cambio de Tabs
    if (tabLeccion && tabSeccion && fieldsLeccion && fieldsSeccion && formTipo) {
      tabLeccion.onclick = () => {
        tabLeccion.className = "flex-1 py-3 text-sm font-semibold text-[var(--color-primary)] border-b-2 border-[var(--color-primary)] cursor-pointer focus:outline-none";
        tabSeccion.className = "flex-1 py-3 text-sm font-semibold text-[var(--color-muted)] border-b-2 border-transparent hover:text-[var(--color-text)] cursor-pointer focus:outline-none";
        fieldsLeccion.classList.remove('hidden');
        fieldsSeccion.classList.add('hidden');
        formTipo.value = "leccion";
      };

      tabSeccion.onclick = () => {
        tabSeccion.className = "flex-1 py-3 text-sm font-semibold text-[var(--color-primary)] border-b-2 border-[var(--color-primary)] cursor-pointer focus:outline-none";
        tabLeccion.className = "flex-1 py-3 text-sm font-semibold text-[var(--color-muted)] border-b-2 border-transparent hover:text-[var(--color-text)] cursor-pointer focus:outline-none";
        fieldsSeccion.classList.remove('hidden');
        fieldsLeccion.classList.add('hidden');
        formTipo.value = "seccion";
      };
    }

    // Submit del formulario
    if (form) {
      form.onsubmit = async (e) => {
        e.preventDefault();

        if (statusDiv) {
          statusDiv.classList.remove('hidden', 'text-error', 'text-success');
          statusDiv.classList.add('text-[var(--color-text)]');
          statusDiv.textContent = 'Enviando...';
        }

        const tipo = formTipo.value;
        let payload: any = { tipo };

        if (tipo === 'seccion') {
          payload.id = (document.getElementById('form-seccionNum') as HTMLInputElement).value.trim();
          payload.titulo = (document.getElementById('form-tituloSeccion') as HTMLInputElement).value.trim();
          payload.slug = (document.getElementById('form-seccionSlug') as HTMLInputElement).value.trim();
          payload.orden = Number((document.getElementById('form-seccionOrden') as HTMLInputElement).value.trim());

          if (!payload.id || !payload.titulo || !payload.slug || isNaN(payload.orden)) {
            if (statusDiv) {
              statusDiv.classList.add('text-error');
              statusDiv.textContent = 'Por favor, rellena todos los campos de la sección.';
            }
            return;
          }
        } else {
          payload.seccionId = (document.getElementById('form-seccionId') as HTMLSelectElement).value;
          payload.lessonNumber = Number((document.getElementById('form-lessonNumber') as HTMLInputElement).value.trim());
          payload.titulo = (document.getElementById('form-tituloLeccion') as HTMLInputElement).value.trim();
          payload.duracion = (document.getElementById('form-duracion') as HTMLInputElement).value.trim();

          if (!payload.seccionId || isNaN(payload.lessonNumber) || !payload.titulo) {
            if (statusDiv) {
              statusDiv.classList.add('text-error');
              statusDiv.textContent = 'Por favor, rellena todos los campos requeridos de la lección.';
            }
            return;
          }
        }

        try {
          const res = await fetch('/api/crear', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await res.json();

          if (res.ok && data.success) {
            if (statusDiv) {
              statusDiv.classList.remove('text-[var(--color-text)]');
              statusDiv.classList.add('text-success');
              statusDiv.textContent = '¡Creado con éxito! Recargando...';
            }
            setTimeout(() => {
              closeModal();
              window.location.reload();
            }, 1000);
          } else {
            if (statusDiv) {
              statusDiv.classList.add('text-error');
              statusDiv.textContent = data.error || 'Ocurrió un error al guardar.';
            }
          }
        } catch (err: any) {
          if (statusDiv) {
            statusDiv.classList.add('text-error');
            statusDiv.textContent = 'Error de conexión: ' + err.message;
          }
        }
      };
    }
  }

  // Setup on load and page transition
  setupCreator();
  document.addEventListener('astro:page-load', setupCreator);
</script>
