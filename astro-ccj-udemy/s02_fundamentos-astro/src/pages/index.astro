---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const [curso] = await getCollection('curso');
const secciones = await getCollection('secciones');
secciones.sort((a, b) => a.data.orden - b.data.orden);
const lecciones = await getCollection('lecciones');
const leccionesPorSeccion = new Map<string, number>();
for (const l of lecciones) {
  leccionesPorSeccion.set(l.data.seccionId, (leccionesPorSeccion.get(l.data.seccionId) ?? 0) + 1);
}
const totalSecciones = secciones.length;
---

<BaseLayout title={`${curso.data.titulo} — ${curso.data.instructor}`}>
  <main class="min-h-screen px-4 sm:px-6 lg:px-8 py-12" transition:animate="fade">
    <div class="max-w-5xl mx-auto">
      <!-- Cabecera del curso -->
      <header class="mb-10">
        <div class="flex items-center gap-4">
          <div
            class="flex items-center justify-center w-12 h-12 rounded-2xl
                   bg-[var(--color-primary)]/10 text-[var(--color-primary)] shrink-0"
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h1 class="text-2xl sm:text-3xl font-extrabold text-[var(--color-heading)] leading-tight">
              {curso.data.titulo}
            </h1>
            <p class="text-sm text-[var(--color-muted)] mt-0.5">
              {curso.data.instructor} · {totalSecciones} secciones
            </p>
          </div>
        </div>

        <!-- Progreso global del curso -->
        <div class="card mt-6">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-medium text-[var(--color-muted)]">Progreso total del curso</span>
            <span id="progreso-global-texto" class="text-xs font-medium text-[var(--color-primary)]">
              0 / {totalSecciones}
            </span>
          </div>
          <div class="w-full h-2 bg-[var(--color-border)] rounded-full overflow-hidden">
            <div
              id="progreso-global-barra"
              class="h-full bg-[var(--color-primary)] rounded-full transition-all duration-700"
              style="width: 0%"
            ></div>
          </div>
        </div>
      </header>

      <!-- Bento Grid: tarjetas de secciones -->
      <div class="bento-grid" id="bento-secciones">
        {secciones.map((seccion, i) => {
          const numLecciones = leccionesPorSeccion.get(seccion.data.id) ?? 0;
          return (
          <a
            href={`/secciones/${seccion.data.slug}`}
            class="card card-hover group cursor-pointer no-underline block"
            data-seccion-id={seccion.data.id}
            data-slug={seccion.data.slug}
          >
            <div class="flex items-start gap-4">
              <div class="badge">{String(i + 1).padStart(2, '0')}</div>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm font-semibold text-[var(--color-heading)] group-hover:text-[var(--color-primary)] transition-colors">
                  {seccion.data.titulo}
                </h3>
                <p class="text-xs text-[var(--color-muted)] mt-1">
                  {numLecciones} lecciones
                </p>
                <!-- Barra de progreso individual -->
                <div class="mt-3" data-progreso-seccion>
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-[10px] font-medium text-[var(--color-muted)]">Progreso</span>
                    <span class="text-[10px] font-medium text-[var(--color-primary)]" data-progreso-texto>0%</span>
                  </div>
                  <div class="w-full h-1.5 bg-[var(--color-border)] rounded-full overflow-hidden">
                    <div
                      class="h-full bg-[var(--color-primary)] rounded-full transition-all duration-500"
                      data-progreso-barra
                      style="width: 0%"
                    ></div>
                  </div>
                </div>
              </div>
            </div>
          </a>
          );
        })}
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  function recalcAll() {
    const secciones = document.querySelectorAll('[data-seccion-id]');
    let completadas = 0;
    const total = secciones.length;

    secciones.forEach((el) => {
      const htmlEl = el as HTMLElement;
      const slug = htmlEl.dataset.slug;
      const storageKey = 'progreso-astro-wordpress-' + slug;
      let ids: string[] = [];
      try {
        ids = JSON.parse(localStorage.getItem(storageKey) || '[]');
      } catch {
        ids = [];
      }

      const leccionesEnSlug = el.querySelector('[data-progreso-seccion]');
      if (leccionesEnSlug) {
        const p = el.querySelector('p.text-xs');
        let totalLecciones = 0;
        if (p && p.textContent) {
          const match = p.textContent.match(/(\d+)\s*lecciones/);
          if (match) totalLecciones = parseInt(match[1], 10);
        }

        const hechas = ids.length;
        const pct = totalLecciones > 0 ? Math.round((hechas / totalLecciones) * 100) : 0;

        const barra = el.querySelector('[data-progreso-barra]') as HTMLElement;
        const texto = el.querySelector('[data-progreso-texto]');
        if (barra) barra.style.width = pct + '%';
        if (texto) texto.textContent = pct + '%';

        if (totalLecciones > 0 && hechas >= totalLecciones) {
          completadas++;
        }
      }
    });

    const barraGlobal = document.getElementById('progreso-global-barra');
    const textoGlobal = document.getElementById('progreso-global-texto');
    if (barraGlobal && textoGlobal) {
      const pctGlobal = total > 0 ? Math.round((completadas / total) * 100) : 0;
      barraGlobal.style.width = pctGlobal + '%';
      textoGlobal.textContent = `${completadas} / ${total}`;
    }
  }

  // Ejecutar en la carga inicial y tras cada transición de página de Astro
  recalcAll();
  document.addEventListener('astro:page-load', recalcAll);

  // Escuchar cambios de progreso
  window.addEventListener('storage', recalcAll);
  window.addEventListener('progreso-update', recalcAll);
</script>
