---
import '../styles/global.css';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  title?: string;
}

const { title = 'Aprende Astro y Headless WordPress — Curso completo' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      // =============================================
      // Theme system — global, site-wide
      // =============================================
      window.__theme = (function () {
        var STORAGE_KEY = 'theme-preference';

        function getTheme() {
          return localStorage.getItem(STORAGE_KEY) || 'light';
        }

        function applyTheme(theme) {
          document.documentElement.classList.remove('dark', 'light');
          document.documentElement.classList.add(theme);

          var icon = document.getElementById('theme-icon');
          if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌕';

          var btn = document.getElementById('theme-toggle');
          if (btn) {
            var label =
              theme === 'dark'
                ? 'Cambiar a modo claro (Ctrl+L)'
                : 'Cambiar a modo oscuro (Ctrl+L)';
            btn.setAttribute('title', label);
            btn.setAttribute('aria-label', label);
          }
        }

        function toggleTheme() {
          var current = getTheme();
          var next = current === 'dark' ? 'light' : 'dark';
          localStorage.setItem(STORAGE_KEY, next);
          applyTheme(next);
        }

        // --- FOUC prevention (before first paint) ---
        applyTheme(getTheme());

        // --- Expose globals ---
        window.toggleTheme = toggleTheme;
        window.__applyTheme = applyTheme;

        return { applyTheme: applyTheme, getTheme: getTheme };
      })();

      // --- Keyboard shortcut Ctrl+L (once) ---
      if (!window.__themeKeyboardInit) {
        window.__themeKeyboardInit = true;
        document.addEventListener('keydown', function (e) {
          if (e.ctrlKey && e.key.toLowerCase() === 'l') {
            e.preventDefault();
            window.__theme.toggleTheme();
          }
        });
      }
    </script>

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <ThemeSwitcher />

    <!-- Sync icon on every ViewTransition navigation -->
    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        window.__theme.applyTheme(window.__theme.getTheme());
      });
    </script>
  </body>
</html>
