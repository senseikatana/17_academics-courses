---
import BaseLayout from '../layouts/BaseLayout.astro';
import { cursos } from '../data/cursos';

const curso = cursos[0];
const totalLecciones = curso.secciones.reduce(
  (acc, s) => acc + s.lecciones.length,
  0
);
---

<BaseLayout title="Curso: {curso.titulo}">
  <main class="min-h-screen px-4 sm:px-6 lg:px-8 py-12" transition:animate="fade">
    <div class="max-w-3xl mx-auto">
      <!-- Cabecera del curso -->
      <header class="mb-10 text-center">
        <h1
          class="text-3xl sm:text-4xl font-extrabold text-[var(--color-heading)] leading-tight"
        >
          {curso.titulo}
        </h1>
        <p class="mt-2 text-lg text-[var(--color-muted)]">
          Instructor: {curso.instructor}
        </p>
        <p class="text-sm text-[var(--color-muted)] mt-1">
          {totalLecciones} lecciones en {curso.secciones.length} secciones
        </p>
      </header>

      <!-- Barra de progreso global (se actualiza con JS) -->
      <div class="mb-8 bg-[var(--color-card)] border border-[var(--color-border)] rounded-2xl p-5">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-semibold text-[var(--color-heading)]">
            Progreso total
          </span>
          <span id="progreso-texto" class="text-sm font-medium text-[var(--color-primary)]">
            0 / {totalLecciones}
          </span>
        </div>
        <div class="w-full h-3 bg-[var(--color-border)] rounded-full overflow-hidden">
          <div
            id="progreso-barra"
            class="h-full bg-[var(--color-primary)] rounded-full transition-all duration-500"
            style="width: 0%"
          ></div>
        </div>
      </div>

      <!-- Lista de secciones -->
      <div class="space-y-4">
        {curso.secciones.map((seccion, idx) => (
          <a
            href={`/${seccion.slug}`}
            class="block group"
          >
            <article
              class="bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-5
                     hover:shadow-[var(--shadow-md)] transition-all duration-300"
            >
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span
                    class="flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold
                           bg-[var(--color-primary)]/10 text-[var(--color-primary)]"
                  >
                    {seccion.id}
                  </span>
                  <div>
                    <h2
                      class="text-base sm:text-lg font-semibold text-[var(--color-heading)]
                             group-hover:text-[var(--color-primary)] transition-colors"
                    >
                      {seccion.titulo}
                    </h2>
                    <p class="text-xs text-[var(--color-muted)] mt-0.5">
                      {seccion.lecciones.length} lecciones
                    </p>
                  </div>
                </div>

                <div class="flex items-center gap-3">
                  <!-- Mini barra por sección -->
                  <div class="hidden sm:block w-24 h-2 bg-[var(--color-border)] rounded-full overflow-hidden">
                    <div
                      class="h-full bg-[var(--color-primary)] rounded-full transition-all duration-500 seccion-progreso"
                      data-seccion={seccion.slug}
                      style="width: 0%"
                    ></div>
                  </div>
                  <span
                    class="text-xs font-medium text-[var(--color-muted)] seccion-contador"
                    data-seccion={seccion.slug}
                  >
                    0/{seccion.lecciones.length}
                  </span>
                  <svg
                    class="w-4 h-4 text-[var(--color-muted)] group-hover:text-[var(--color-primary)] transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  (function () {
    const STORAGE_PREFIX = 'progreso-astro-wordpress-';

    function calcularProgreso() {
      let globalHechas = 0;
      let globalTotal = 0;

      document.querySelectorAll('.seccion-progreso').forEach((barra) => {
        const seccion = barra.dataset.seccion;
        const storage = JSON.parse(
          localStorage.getItem(STORAGE_PREFIX + seccion) || '[]'
        );

        // Contar lecciones de esta sección desde el DOM
        const contador = document.querySelector(
          `.seccion-contador[data-seccion="${seccion}"]`
        );
        if (!contador) return;

        const total = parseInt(contador.textContent.split('/')[1], 10);
        const hechas = storage.length;
        const pct = total > 0 ? Math.min((hechas / total) * 100, 100) : 0;

        barra.style.width = pct + '%';
        contador.textContent = `${hechas}/${total}`;

        globalHechas += hechas;
        globalTotal += total;
      });

      // Progreso global
      const barraGlobal = document.getElementById('progreso-barra');
      const textoGlobal = document.getElementById('progreso-texto');
      if (barraGlobal && textoGlobal) {
        const pct = globalTotal > 0 ? (globalHechas / globalTotal) * 100 : 0;
        barraGlobal.style.width = pct + '%';
        textoGlobal.textContent = `${globalHechas} / ${globalTotal}`;
      }
    }

    // Calcular al cargar
    calcularProgreso();

    // Listeners globales una sola vez (inmunes a ViewTransitions)
    if (!window.__progresoInit) {
      window.__progresoInit = true;
      window.addEventListener('storage', calcularProgreso);
    }
  })();
</script>
