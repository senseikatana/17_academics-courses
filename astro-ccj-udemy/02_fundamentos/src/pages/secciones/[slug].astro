---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { cursos, getSeccionPorSlug } from '../../data/cursos';

export function getStaticPaths() {
  const curso = cursos[0];
  return curso.secciones.map((seccion) => ({
    params: { slug: seccion.slug },
    props: { seccion },
  }));
}

export interface Props {
  seccion: import('../../data/cursos').Seccion;
}

const { seccion } = Astro.props;
const curso = cursos[0];
const idx = curso.secciones.findIndex((s) => s.id === seccion.id);
const seccionAnterior = idx > 0 ? curso.secciones[idx - 1] : null;
const seccionSiguiente =
  idx < curso.secciones.length - 1 ? curso.secciones[idx + 1] : null;
---

<BaseLayout title={`${seccion.id}. ${seccion.titulo} — ${curso.titulo}`}>
  <main class="min-h-screen px-4 sm:px-6 lg:px-8 py-12" transition:animate="fade">
    <div class="max-w-2xl mx-auto">
      <!-- Navegación superior -->
      <nav class="mb-6">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                 hover:text-[var(--color-primary-hover)] transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
          Volver al índice
        </a>
      </nav>

      <!-- Cabecera de la sección -->
      <header class="mb-8">
        <span
          class="inline-block px-3 py-1 rounded-full text-xs font-semibold
                 bg-[var(--color-primary)]/10 text-[var(--color-primary)] mb-3"
        >
          Sección {seccion.id}
        </span>
        <h1
          class="text-2xl sm:text-3xl font-extrabold text-[var(--color-heading)] leading-tight"
        >
          {seccion.titulo}
        </h1>
        <p class="mt-1 text-sm text-[var(--color-muted)]">
          {seccion.lecciones.length} lecciones
        </p>

        <!-- Barra de progreso de la sección -->
        <div class="mt-4 bg-[var(--color-card)] border border-[var(--color-border)] rounded-xl p-4">
          <div class="flex items-center justify-between mb-1.5">
            <span class="text-xs font-medium text-[var(--color-muted)]">Progreso</span>
            <span id="progreso-seccion-texto" class="text-xs font-medium text-[var(--color-primary)]">
              0 / {seccion.lecciones.length}
            </span>
          </div>
          <div class="w-full h-2 bg-[var(--color-border)] rounded-full overflow-hidden">
            <div
              id="progreso-seccion-barra"
              class="h-full bg-[var(--color-primary)] rounded-full transition-all duration-500"
              style="width: 0%"
            ></div>
          </div>
        </div>
      </header>

      <!-- Lista de lecciones con checkboxes -->
      <ul class="space-y-2" id="lista-lecciones">
        {seccion.lecciones.map((leccion) => (
          <li
            class="flex items-center gap-3 bg-[var(--color-card)] border border-[var(--color-border)]
                   rounded-xl px-4 py-3.5 transition-all duration-300 leccion-item"
            data-leccion-id={leccion.id}
          >
            <input
              type="checkbox"
              id={"chk-" + leccion.id}
              data-leccion-id={leccion.id}
              class="w-5 h-5 rounded border-[var(--color-border)] text-[var(--color-primary)]
                     focus:ring-[var(--color-primary)] cursor-pointer
                     accent-[var(--color-primary)] transition-transform duration-200 hover:scale-110"
            />
            <label
              for={"chk-" + leccion.id}
              class="flex-1 text-sm sm:text-base text-[var(--color-text)] cursor-pointer
                     select-none leading-snug transition-colors duration-300 leccion-label"
            >
              {leccion.titulo}
            </label>
          </li>
        ))}
      </ul>

      <!-- Navegación entre secciones -->
      <nav class="mt-10 flex items-center justify-between border-t border-[var(--color-border)] pt-6">
        {seccionAnterior ? (
          <a
            href={`/secciones/${seccionAnterior.slug}`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                   hover:text-[var(--color-primary-hover)] transition-colors"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            {seccionAnterior.titulo}
          </a>
        ) : (
          <div></div>
        )}

        {seccionSiguiente ? (
          <a
            href={`/secciones/${seccionSiguiente.slug}`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-primary)]
                   hover:text-[var(--color-primary-hover)] transition-colors"
          >
            {seccionSiguiente.titulo}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ) : (
          <div></div>
        )}
      </nav>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ slug: seccion.slug }}>
  (function () {
    const STORAGE_KEY = `progreso-astro-wordpress-${slug}`;

    const checkboxes = document.querySelectorAll(
      '#lista-lecciones input[type="checkbox"]'
    );
    const barraProgreso = document.getElementById('progreso-seccion-barra');
    const textoProgreso = document.getElementById('progreso-seccion-texto');
    const totalLecciones = checkboxes.length;

    /** Cargar IDs completados desde localStorage */
    function loadCompleted() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
      } catch {
        return [];
      }
    }

    /** Guardar array de IDs completados */
    function saveCompleted(ids) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(ids));
      // Disparar evento para que otras pestañas/el dashboard se actualicen
      window.dispatchEvent(new Event('storage'));
    }

    /** Sincronizar checkboxes con localStorage */
    function syncCheckboxes() {
      const completed = loadCompleted();
      checkboxes.forEach((cb) => {
        cb.checked = completed.includes(cb.dataset.leccionId);
      });
      actualizarProgreso();
    }

    /** Actualizar barra y texto de progreso */
    function actualizarProgreso() {
      const hechas = Array.from(checkboxes).filter((cb) => cb.checked).length;
      const pct = totalLecciones > 0 ? (hechas / totalLecciones) * 100 : 0;

      if (barraProgreso) barraProgreso.style.width = pct + '%';
      if (textoProgreso) textoProgreso.textContent = `${hechas} / ${totalLecciones}`;
    }

    /** Marcar/desmarcar y persistir */
    function handleToggle(e) {
      const cb = e.currentTarget;
      const completed = loadCompleted();
      const id = cb.dataset.leccionId;

      if (cb.checked) {
        if (!completed.includes(id)) completed.push(id);
      } else {
        const i = completed.indexOf(id);
        if (i > -1) completed.splice(i, 1);
      }

      saveCompleted(completed);
      actualizarProgreso();

      // Animación sutil en el item
      const item = cb.closest('.leccion-item');
      if (item) {
        item.classList.add('scale-[1.02]');
        setTimeout(() => item.classList.remove('scale-[1.02]'), 200);
      }
    }

    // --- Init ---
    if (checkboxes.length > 0) {
      syncCheckboxes();

      checkboxes.forEach((cb) => {
        cb.addEventListener('change', handleToggle);
      });

      // Re-sincronizar si hay cambios desde otra pestaña
      window.addEventListener('storage', syncCheckboxes);
    }
  })();
</script>
