---
/**
 * ThemeSwitcher
 *
 * Botón flotante (inferior-derecho) que alterna entre modo claro ☀️ y oscuro 🌕.
 * - Persiste la preferencia en localStorage.
 * - Aplica clase `.dark` o `.light` en <html>.
 * - Atajo de teclado: Ctrl+L.
 * - Muestra el icono CONTRARIO al tema actual (lo que va a pasar al hacer click).
 */
---

<button
  id="theme-toggle"
  class="fixed bottom-6 right-6 flex items-center justify-center w-12 h-12 rounded-full z-50
         bg-[var(--color-card)] text-[var(--color-text)]
         border border-[var(--color-border)]
         shadow-[var(--shadow-lg)]
         hover:shadow-[var(--shadow-md)]
         hover:scale-110 active:scale-95
         focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:ring-offset-2 focus:ring-offset-[var(--color-bg)]
         transition-transform duration-300 ease-out
         cursor-pointer"
  aria-label="Cambiar a modo oscuro"
  title="Cambiar a modo oscuro (Ctrl+L)"
>
  <span id="theme-icon">🌕</span>
</button>

<script>
  (function () {
    const STORAGE_KEY = 'theme-preference';

    const btn = document.getElementById('theme-toggle');
    const icon = document.getElementById('theme-icon');

    // --- Evitar acumulación de listeners en View Transitions ---
    if (btn.dataset.initialized) return;
    btn.dataset.initialized = 'true';

    /** Return the stored theme or 'light' as default */
    function getStoredTheme() {
      return localStorage.getItem(STORAGE_KEY) || 'light';
    }

    /** Toggle theme and update everything */
    function toggleTheme() {
      const current = getStoredTheme();
      const next = current === 'dark' ? 'light' : 'dark';
      saveTheme(next);
      applyTheme(next);
    }

    /** Apply theme to <html> and update UI */
    function applyTheme(theme) {
      const html = document.documentElement;
      html.classList.remove('dark', 'light');
      html.classList.add(theme);

      const isDark = theme === 'dark';

      // Muestra el icono CONTRARIO al tema actual:
      //   - Si es dark → ☀️ sol (click → light)
      //   - Si es light → 🌕 luna llena (click → dark)
      icon.textContent = isDark ? '☀️' : '🌕';

      // Tooltip y aria-label dinámicos
      const label = isDark
        ? 'Cambiar a modo claro (Ctrl+L)'
        : 'Cambiar a modo oscuro (Ctrl+L)';
      btn.setAttribute('title', label);
      btn.setAttribute('aria-label', label);
    }

    /** Persist the choice */
    function saveTheme(theme) {
      localStorage.setItem(STORAGE_KEY, theme);
    }

    // --- Click handler ---
    btn.addEventListener('click', toggleTheme);

    // --- Keyboard shortcut: Ctrl+L (como Notion) ---
    document.addEventListener('keydown', function (e) {
      if (e.ctrlKey && e.key.toLowerCase() === 'l') {
        e.preventDefault();
        toggleTheme();
      }
    });

    // --- Boot ---
    applyTheme(getStoredTheme());
  })();
</script>
